endLine":263,"endColumn":5},{"ruleId":"no-restricted-syntax","severity":2,"message":"\"it\" should start with \"should\"","line":265,"column":3,"nodeType":"CallExpression","messageId":"restrictedSyntax","endLine":282,"endColumn":5},{"ruleId":"no-restricted-syntax","severity":2,"message":"\"it\" should start with \"should\"","line":286,"column":3,"nodeType":"CallExpression","messageId":"restrictedSyntax","endLine":292,"endColumn":5}],"suppressedMessages":[],"errorCount":23,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { ConditionEvaluatorService } from './condition-evaluator.service';\nimport { ConditionGroup } from './condition-evaluator.service';\n\ndescribe('ConditionEvaluatorService', () => {\n  let service: ConditionEvaluatorService;\n\n  beforeEach(() => {\n    service = new ConditionEvaluatorService();\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Empty / No Conditions О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('should return true for empty rules (pass-through)', () => {\n    const group: ConditionGroup = { logic: 'AND', rules: [] };\n    expect(service.evaluate(group, { status: 'New' })).toBe(true);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ AND logic О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('AND: all conditions match О“ГҘГҶ true', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        { field: 'source', operator: 'eq', value: 'Website' },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'New', source: 'Website' })).toBe(\n      true,\n    );\n  });\n\n  it('AND: one condition fails О“ГҘГҶ false', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        { field: 'source', operator: 'eq', value: 'Website' },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'New', source: 'Facebook' })).toBe(\n      false,\n    );\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ OR logic О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('OR: one condition matches О“ГҘГҶ true', () => {\n    const group: ConditionGroup = {\n      logic: 'OR',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        { field: 'status', operator: 'eq', value: 'Open' },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'Open' })).toBe(true);\n  });\n\n  it('OR: no conditions match О“ГҘГҶ false', () => {\n    const group: ConditionGroup = {\n      logic: 'OR',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        { field: 'status', operator: 'eq', value: 'Open' },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'Closed' })).toBe(false);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Nested groups О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('Nested: AND([status=New, OR([source=Web, source=FB])]) О“ГҘГҶ true', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        {\n          logic: 'OR',\n          rules: [\n            { field: 'source', operator: 'eq', value: 'Website' },\n            { field: 'source', operator: 'eq', value: 'Facebook' },\n          ],\n        },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'New', source: 'Facebook' })).toBe(\n      true,\n    );\n  });\n\n  it('Nested: AND([status=New, OR([source=Web, source=FB])]) with source=Zalo О“ГҘГҶ false', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        { field: 'status', operator: 'eq', value: 'New' },\n        {\n          logic: 'OR',\n          rules: [\n            { field: 'source', operator: 'eq', value: 'Website' },\n            { field: 'source', operator: 'eq', value: 'Facebook' },\n          ],\n        },\n      ],\n    };\n    expect(service.evaluate(group, { status: 'New', source: 'Zalo' })).toBe(\n      false,\n    );\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Numeric operators О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('gt: amount > 1000 О“ГҘГҶ true when amount=1500', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'amount', operator: 'gt', value: 1000 }],\n    };\n    expect(service.evaluate(group, { amount: 1500 })).toBe(true);\n  });\n\n  it('gt: amount > 1000 О“ГҘГҶ false when amount=500', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'amount', operator: 'gt', value: 1000 }],\n    };\n    expect(service.evaluate(group, { amount: 500 })).toBe(false);\n  });\n\n  it('lt: priority < 3 О“ГҘГҶ true when priority=1', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'priority', operator: 'lt', value: 3 }],\n    };\n    expect(service.evaluate(group, { priority: 1 })).toBe(true);\n  });\n\n  it('gte: score >= 80 О“ГҘГҶ true when score=80', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'score', operator: 'gte', value: 80 }],\n    };\n    expect(service.evaluate(group, { score: 80 })).toBe(true);\n  });\n\n  it('lte: score <= 80 О“ГҘГҶ false when score=90', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'score', operator: 'lte', value: 80 }],\n    };\n    expect(service.evaluate(group, { score: 90 })).toBe(false);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ String operators О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('contains: name contains \"Nguyen\" О“ГҘГҶ case-insensitive match', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'name', operator: 'contains', value: 'nguyen' }],\n    };\n    expect(service.evaluate(group, { name: 'Nguyen Van A' })).toBe(true);\n  });\n\n  it('not_contains: name not_contains \"xyz\" О“ГҘГҶ true', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'name', operator: 'not_contains', value: 'xyz' }],\n    };\n    expect(service.evaluate(group, { name: 'Nguyen Van A' })).toBe(true);\n  });\n\n  it('neq: status != \"Closed\" О“ГҘГҶ true when \"Open\"', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'status', operator: 'neq', value: 'Closed' }],\n    };\n    expect(service.evaluate(group, { status: 'Open' })).toBe(true);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Null / Empty operators О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('is_empty: О“ГҘГҶ true when field is null', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'email', operator: 'is_empty', value: '' }],\n    };\n    expect(service.evaluate(group, { email: null })).toBe(true);\n  });\n\n  it('is_empty: О“ГҘГҶ true when field is undefined', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'email', operator: 'is_empty', value: '' }],\n    };\n    expect(service.evaluate(group, {})).toBe(true);\n  });\n\n  it('is_empty: О“ГҘГҶ true when field is empty string', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'email', operator: 'is_empty', value: '' }],\n    };\n    expect(service.evaluate(group, { email: '  ' })).toBe(true);\n  });\n\n  it('is_not_empty: О“ГҘГҶ true when field has value', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'email', operator: 'is_not_empty', value: '' }],\n    };\n    expect(service.evaluate(group, { email: 'test@example.com' })).toBe(true);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Null field with comparison operators О“ГҘГҶ false О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('eq: null field О“ГҘГҶ false', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'status', operator: 'eq', value: 'New' }],\n    };\n    expect(service.evaluate(group, { status: null })).toBe(false);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Type mismatch on numeric operators О“ГҘГҶ false О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('gt: text field with numeric operator О“ГҘГҶ false', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'name', operator: 'gt', value: 100 }],\n    };\n    expect(service.evaluate(group, { name: 'not-a-number' })).toBe(false);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ Validation О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('validate: depth > 3 О“ГҘГҶ invalid', () => {\n    // 5 levels of nesting: depth 0 О“ГҘГҶ 1 О“ГҘГҶ 2 О“ГҘГҶ 3 О“ГҘГҶ 4 (exceeds max 3)\n    const deepGroup: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        {\n          logic: 'OR',\n          rules: [\n            {\n              logic: 'AND',\n              rules: [\n                {\n                  logic: 'OR',\n                  rules: [\n                    {\n                      logic: 'AND',\n                      rules: [{ field: 'x', operator: 'eq', value: '1' }],\n                    },\n                  ],\n                },\n              ],\n            },\n          ],\n        },\n      ],\n    };\n    const result = service.validate(deepGroup);\n    expect(result.valid).toBe(false);\n    expect(result.error).toContain('exceeds maximum');\n  });\n\n  it('validate: depth 3 О“ГҘГҶ valid', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [\n        {\n          logic: 'OR',\n          rules: [\n            {\n              logic: 'AND',\n              rules: [{ field: 'x', operator: 'eq', value: '1' }],\n            },\n          ],\n        },\n      ],\n    };\n    const result = service.validate(group);\n    expect(result.valid).toBe(true);\n  });\n\n  // О“Г¶ГҮО“Г¶ГҮ String numeric coercion (eq with string numbers) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  it('eq: numeric coercion О“ГҮГ¶ \"100\" eq 100 О“ГҘГҶ true', () => {\n    const group: ConditionGroup = {\n      logic: 'AND',\n      rules: [{ field: 'amount', operator: 'eq', value: 100 }],\n    };\n    expect(service.evaluate(group, { amount: '100' })).toBe(true);\n  });\n});\n","usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\engine\\condition-evaluator.service.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\engine\\loop-prevention.service.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\engine\\workflow-orchestrator.service.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\events\\automation-event-listener.service.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'buildAutomationEventName' is defined but never used.","line":5,"column":3,"nodeType":null,"messageId":"unusedVar","endLine":5,"endColumn":27}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Injectable, Logger } from '@nestjs/common';\nimport { OnEvent } from '@nestjs/event-emitter';\nimport {\n  AutomationEventPayload,\n  buildAutomationEventName,\n} from './automation-event.payload';\nimport { AutomationWorkflowRepository } from '../infrastructure/persistence/document/repositories/automation-workflow.repository';\nimport { WorkflowOrchestratorService } from '../engine/workflow-orchestrator.service';\n\n/**\n * AutomationEventListenerService О“ГҮГ¶ listens for CRM object events\n * and finds matching active workflows.\n *\n * This is the entry point of the Automation Engine. When ContactsService\n * or TicketsService emit an event, this listener:\n *   1. Queries active workflows matching the event + object type\n *   2. Filters out self-triggered workflows (loop prevention Layer 0)\n *   3. Delegates to WorkflowOrchestratorService (Task 1.6) for execution\n *\n * @see docs/prd-visual-automation-builder.md О“ГҮГ¶ Task 1.2\n */\n@Injectable()\nexport class AutomationEventListenerService {\n  private readonly logger = new Logger(AutomationEventListenerService.name);\n\n  constructor(\n    private readonly workflowRepo: AutomationWorkflowRepository,\n    private readonly orchestrator: WorkflowOrchestratorService,\n  ) {}\n\n  // О“Г¶ГҮО“Г¶ГҮ Wildcard listener for all automation events О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  @OnEvent('automation.**')\n  async handleAutomationEvent(payload: AutomationEventPayload): Promise<void> {\n    const { tenantId, event, object, recordId } = payload;\n    const depth = payload.automationDepth ?? 0;\n\n    this.logger.log(\n      `[Event] ${event}.${object} | tenant=${tenantId} record=${recordId} depth=${depth}`,\n    );\n\n    try {\n      // Find all active workflows that match this event + object\n      const workflows = await this.workflowRepo.findActiveByTrigger(\n        tenantId,\n        event,\n        object,\n      );\n\n      if (workflows.length === 0) {\n        this.logger.debug(\n          `No active workflows match ${event}.${object} for tenant ${tenantId}`,\n        );\n        return;\n      }\n\n      // Filter out self-triggered workflows (Layer 0: same-workflow prevention)\n      const eligibleWorkflows = workflows.filter((wf) => {\n        if (\n          payload._automationSourceWorkflowId &&\n          wf._id.toString() === payload._automationSourceWorkflowId\n        ) {\n          this.logger.debug(\n            `Skipping workflow \"${wf.name}\" (${wf._id}) О“ГҮГ¶ self-trigger from automation`,\n          );\n          return false;\n        }\n\n        // For field_updated triggers with specific field, check if the changed\n        // field matches the configured trigger field\n        if (\n          event === 'field_updated' &&\n          wf.triggerConfig.field &&\n          payload.changedFields\n        ) {\n          return payload.changedFields.includes(wf.triggerConfig.field);\n        }\n\n        return true;\n      });\n\n      this.logger.log(\n        `Found ${eligibleWorkflows.length} eligible workflow(s) for ${event}.${object} (record=${recordId})`,\n      );\n\n      // Delegate to WorkflowOrchestratorService for each eligible workflow\n      for (const wf of eligibleWorkflows) {\n        this.logger.log(\n          `  О“ГҘГҶ Triggering workflow \"${wf.name}\" (${wf._id}) [depth=${depth}]`,\n        );\n        // Execute each workflow independently О“ГҮГ¶ one failure doesn't block others\n        try {\n          await this.orchestrator.execute(wf, payload);\n        } catch (wfError: any) {\n          this.logger.error(\n            `Workflow \"${wf.name}\" (${wf._id}) execution failed: ${wfError.message}`,\n          );\n        }\n      }\n    } catch (error: any) {\n      this.logger.error(\n        `Error handling automation event ${event}.${object} for record ${recordId}: ${error.message}`,\n        error.stack,\n      );\n    }\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\events\\automation-event.payload.ts","messages":[],"suppressedMessag
 is defined but never used.","line":3,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":3,"endColumn":42},{"ruleId":"@typescript-eslint/require-await","severity":2,"message":"Async method 'execute' has no 'await' expression.","line":29,"column":3,"nodeType":"FunctionExpression","messageId":"missingAwait","endLine":29,"endColumn":16,"suggestions":[{"messageId":"removeAsync","fix":{"range":[1047,1122],"text":"execute(job: AutomationActionJobData): ActionExecutionResult"},"desc":"Remove 'async'."}]},{"ruleId":"@typescript-eslint/require-await","severity":2,"message":"Async method 'execute' has no 'await' expression.","line":78,"column":3,"nodeType":"FunctionExpression","messageId":"missingAwait","endLine":78,"endColumn":16,"suggestions":[{"messageId":"removeAsync","fix":{"range":[2642,2717],"text":"execute(job: AutomationActionJobData): ActionExecutionResult"},"desc":"Remove 'async'."}]},{"ruleId":"@typescript-eslint/require-await","severity":2,"message":"Async method 'execute' has no 'await' expression.","line":131,"column":3,"nodeType":"FunctionExpression","messageId":"missingAwait","endLine":131,"endColumn":16,"suggestions":[{"messageId":"removeAsync","fix":{"range":[4291,4366],"text":"execute(job: AutomationActionJobData): ActionExecutionResult"},"desc":"Remove 'async'."}]},{"ruleId":"@typescript-eslint/require-await","severity":2,"message":"Async method 'execute' has no 'await' expression.","line":172,"column":3,"nodeType":"FunctionExpression","messageId":"missingAwait","endLine":172,"endColumn":16,"suggestions":[{"messageId":"removeAsync","fix":{"range":[5568,5643],"text":"execute(job: AutomationActionJobData): ActionExecutionResult"},"desc":"Remove 'async'."}]}],"suppressedMessages":[],"errorCount":5,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Injectable, Logger } from '@nestjs/common';\nimport { AutomationActionJobData } from '../queue/automation-queue.constants';\nimport { AutomationExecutionLogRepository } from '../infrastructure/persistence/document/repositories/automation-execution-log.repository';\n\n/**\n * Base interface for all action executors.\n * Each executor handles one action type (email, sms, update_field, route).\n */\nexport interface ActionExecutor {\n  readonly actionType: string;\n  execute(job: AutomationActionJobData): Promise<ActionExecutionResult>;\n}\n\nexport interface ActionExecutionResult {\n  success: boolean;\n  output?: Record<string, any>;\n  error?: { code: string; message: string };\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Send Email Executor\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n@Injectable()\nexport class SendEmailExecutor implements ActionExecutor {\n  readonly actionType = 'send_email';\n  private readonly logger = new Logger(SendEmailExecutor.name);\n\n  async execute(job: AutomationActionJobData): Promise<ActionExecutionResult> {\n    const { recordId, recordData, actionConfig, tenantId } = job;\n    const to = recordData.emails?.[0] || recordData.email;\n    const subject = this.interpolate(actionConfig.subject || '', recordData);\n    const body = this.interpolate(actionConfig.template || '', recordData);\n\n    if (!to) {\n      return {\n        success: false,\n        error: {\n          code: 'NO_EMAIL',\n          message: `Record ${recordId} has no email address`,\n        },\n      };\n    }\n\n    this.logger.log(\n      `[SendEmail] tenant=${tenantId} to=${to} subject=\"${subject}\"`,\n    );\n\n    // TODO: Integrate with actual email provider (SendGrid, SES, etc.)\n    // For now, log the email that would be sent\n    return {\n      success: true,\n      output: { to, subject, bodyLength: body.length },\n    };\n  }\n\n  private interpolate(template: string, data: Record<string, any>): string {\n    return template.replace(/\\{\\{(\\w+(?:\\.\\w+)*)\\}\\}/g, (_, path) => {\n      const keys = path.split('.');\n      let value: any = data;\n      for (const key of keys) {\n        value = value?.[key];\n      }\n      return value !== undefined && value !== null ? String(value) : '';\n    });\n  }\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Send SMS Executor\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n@Injectable()\nexport class SendSmsExecutor implements ActionExecutor {\n  readonly actionType = 'send_sms';\n  private readonly logger = new Logger(SendSmsExecutor.name);\n\n  async execute(job: AutomationActionJobData): Promise<ActionExecutionResult> {\n    const { recordId, recordData, actionConfig, tenantId } = job;\n    const phone = recordData.phones?.[0] || recordData.phone;\n    const message = this.interpolate(actionConfig.message || '', recordData);\n\n    if (!phone) {\n      return {\n        success: false,\n        error: {\n          code: 'NO_PHONE',\n          message: `Record ${recordId} has no phone number`,\n        },\n      };\n    }\n\n    if (message.length > 160) {\n      this.logger.warn(\n        `[SendSMS] Message exceeds 160 chars (${message.length}) for record ${recordId}`,\n      );\n    }\n\n    this.logger.log(\n      `[SendSMS] tenant=${tenantId} to=${phone} chars=${message.length}`,\n    );\n\n    // TODO: Integrate with SMS provider (Twilio, Vonage, etc.)\n    return {\n      success: true,\n      output: { phone, messageLength: message.length },\n    };\n  }\n\n  private interpolate(template: string, data: Record<string, any>): string {\n    return template.replace(/\\{\\{(\\w+(?:\\.\\w+)*)\\}\\}/g, (_, path) => {\n      const keys = path.split('.');\n      let value: any = data;\n      for (const key of keys) {\n        value = value?.[key];\n      }\n      return value !== undefined && value !== null ? String(value) : '';\n    });\n  }\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Update Field Executor\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n@Injectable()\nexport class UpdateFieldExecutor implements ActionExecutor {\n  readonly actionType = 'update_field';\n  private readonly logger = new Logger(UpdateFieldExecutor.name);\n\n  async execute(job: AutomationActionJobData): Promise<ActionExecutionResult> {\n    const { recordId, recordType, actionConfig, tenantId } = job;\n    const field = actionConfig.targetField;\n    const value = actionConfig.targetValue;\n\n    if (!field) {\n      return {\n        success: false,\n        error: { code: 'NO_FIELD', message: 'targetField is required' },\n      };\n    }\n\n    this.logger.log(\n      `[UpdateField] tenant=${tenantId} ${recordType}(${recordId}).${field} = \"${value}\"`,\n    );\n\n    // TODO: Call the appropriate service (ContactsService, TicketsService)\n    // to update the record field. Must set _automationSourceWorkflowId\n    // in the event payload to prevent self-loop triggers.\n    return {\n      success: true,\n      output: {\n        recordType,\n        recordId,\n        field,\n        previousValue: job.recordData[field],\n        newValue: value,\n      },\n    };\n  }\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Route to Team Executor\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n@Injectable()\nexport class RouteToTeamExecutor implements ActionExecutor {\n  readonly actionType = 'route_to_team';\n  private readonly logger = new Logger(RouteToTeamExecutor.name);\n\n  async execute(job: AutomationActionJobData): Promise<ActionExecutionResult> {\n    const { recordId, recordType, actionConfig, tenantId } = job;\n    const teamId = actionConfig.teamId;\n    const userId = actionConfig.userId;\n\n    if (!teamId && !userId) {\n      return {\n        success: false,\n        error: { code: 'NO_TARGET', message: 'teamId or userId is required' },\n      };\n    }\n\n    this.logger.log(\n      `[RouteToTeam] tenant=${tenantId} ${recordType}(${recordId}) О“ГҘГҶ team=${teamId || 'N/A'} user=${userId || 'round-robin'}`,\n    );\n\n    // TODO: Call AssignmentEngineService to route the record to the\n    // specified team/user. For tickets: update groupId + ownerId.\n    // For contacts: update ownerId.\n    return {\n      success: true,\n      output: {\n        recordType,\n        recordId,\n        assignedTeam: teamId,\n        assignedUser: userId || 'round-robin',\n      },\n    };\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\CRM\\crm-api\\src\\automation-rules\\engine\\condition-evaluator.service.spec.ts","messages":[{"ruleId":"no-restricted-syntax","severity":2,"message":"\"it\" should start with \"should\"","line":20,"column":3,"nodeType":"CallExpression","messageId":"restrictedSyntax","endLine":31,"endColumn":5},{"ruleId":"no-restricted-syntax","severity"
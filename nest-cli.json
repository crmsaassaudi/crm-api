{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      { "include": "i18n/**/*", "outDir": "dist", "watchAssets": true },
      {
        "include": "mail/mail-templates/**/*",
        "outDir": "dist",
        "watchAssets": true
      }
    ]
  }
}

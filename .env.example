NODE_ENV=development
APP_PORT=3000
APP_NAME="CRM API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
APP_ROOT_DOMAIN=crm.localhost
FRONTEND_DOMAIN=http://crm.localhost:4200,http://*.crm.localhost:4200,http://localhost:4200,http://127.0.0.1:4200
BACKEND_DOMAIN=http://api.crm.localhost:3000

DATABASE_TYPE=mongodb
DATABASE_PORT=27017
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=crm
DATABASE_URL=mongodb://localhost:27017/crm?replicaSet=rs0

# Audit Trail — separate DB to avoid WiredTiger cache contention
# Leave AUDIT_DATABASE_URL empty to reuse DATABASE_URL (same cluster, different DB name)
# Set to a separate cluster URI for full storage isolation in production
AUDIT_DATABASE_URL=
AUDIT_DATABASE_NAME=crm_audit_logs

# Support "local", "s3", "s3-presigned"
FILE_DRIVER=local
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_S3_REGION=sgp1
AWS_DEFAULT_S3_BUCKET=crmsaudi
# Custom S3-compatible endpoint (e.g. https://sgp1.digitaloceanspaces.com)
AWS_S3_ENDPOINT=https://crmsaudi.sgp1.digitaloceanspaces.com

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=Api
MAIL_CLIENT_PORT=1080

AUTH_JWT_SECRET=replace-with-at-least-32-random-chars
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=replace-with-at-least-32-random-chars
AUTH_REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_FORGOT_SECRET=replace-with-at-least-32-random-chars
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=replace-with-at-least-32-random-chars
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d
CHANNEL_ENCRYPTION_KEY=replace-with-64-char-hex-key-from-openssl-rand-hex-32

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OMNI_VERIFY_TOKEN=crm_omni_2026

OMNI_REPLY_WINDOW_FACEBOOK_HOURS=24
OMNI_REPLY_WINDOW_ZALO_HOURS=24
OMNI_REPLY_WINDOW_WHATSAPP_HOURS=24
OMNI_REPLY_WINDOW_INSTAGRAM_HOURS=24
OMNI_REPLY_WINDOW_LIVECHAT_HOURS=0

CRM_BOT_URL=http://localhost:4203
CRM_BOT_BUILDER_URL=http://localhost:4202
CRM_BOT_INTERNAL_SECRET=replace-with-shared-internal-secret
CRM_BOT_TIMEOUT_MS=3000
CRM_BOT_PROVISION_TIMEOUT_MS=8000

# Bot callback — URL mà crm-bot gọi ngược về để trả kết quả
CRM_API_PUBLIC_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=
GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=http://crm.localhost:4200/settings/email/oauth/callback
MICROSOFT_ENTRA_OAUTH_CLIENT_ID=
MICROSOFT_ENTRA_OAUTH_CLIENT_SECRET=
MICROSOFT_ENTRA_TENANT_ID=common
MICROSOFT_ENTRA_OAUTH_REDIRECT_URI=http://crm.localhost:4200/settings/email/oauth/callback

APPLE_APP_AUDIENCE=[]

WORKER_HOST=redis://redis:6379/1

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_TTL=86400

# Internal service-to-service auth (crm-manager-api → crm-api)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=replace-with-strong-random-secret

# crm-api worker → crm-manager-api realtime webhook (leave empty to disable)
MANAGER_API_INTERNAL_WEBHOOK_URL=http://localhost:3001

KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=crm-saas
KEYCLOAK_CLIENT_ID=crm-api
KEYCLOAK_CLIENT_SECRET=replace-with-real-keycloak-client-secret
KEYCLOAK_ADMIN_CLIENT_ID=crm-api-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=replace-with-real-keycloak-admin-client-secret
KEYCLOAK_CALLBACK_URL=http://api.crm.localhost:3000/api/v1/auth/callback
KEYCLOAK_FRONTEND_URL=http://crm.localhost:4200

# ==============================================================================
# 🎬 AI VIDEO PRODUCTION ENGINE CONFIGURATION
# ==============================================================================
# [REQUIRED] ElevenLabs API Key dùng để lồng tiếng thuyết minh video AI
ELEVENLABS_API_KEY=

# [OPTIONAL] ElevenLabs Voice ID (Mặc định sẽ tự lấy giọng đầu tiên nếu trống)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# [REQUIRED] Đường dẫn tuyệt đối tới tệp nhạc nền BGM (.mp3) trên máy chủ
BGM_PATH=e:/CRM/crm-api/assets/bgm/soft-acoustic.mp3

# [REQUIRED] Đường dẫn tuyệt đối tới tệp ảnh nền slide (.jpg/.png) trên máy chủ
BG_SLIDE_PATH=e:/CRM/crm-api/assets/images/crm-slide.jpg

# [OPTIONAL] API Key cho Gemini (Dùng sinh Caption & Hashtags nháp, fallback heuristic nếu trống)
GEMINI_API_KEY=

# [OPTIONAL] API Key cho OpenAI (Dùng sinh content hoặc fallback cho ElevenLabs voice, fallback heuristic/silence frame nếu trống)
OPENAI_API_KEY=
